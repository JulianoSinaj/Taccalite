# ─────────────────────────────────────────────────────────────────────────────
# Taccalite — environment configuration
# Copy to `.env.local` (dev) or `.env` (prod). Everything has a safe default,
# so the app runs with an empty file; set values to enable real integrations.
# ─────────────────────────────────────────────────────────────────────────────

# Public base URL (canonical/OG/JSON-LD, absolute links in emails)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Database (SQLite file) ───────────────────────────────────────────────────
DATABASE_URL=./data/taccalite.db
# Apply Drizzle migrations when the DB connection is first opened. Defaults ON in
# dev, OFF in production (the container runs them once at start via the entrypoint,
# never on the request path). Leave unset unless you know you want boot migrations.
# RUN_MIGRATIONS_ON_BOOT=1

# ── Sessions ─────────────────────────────────────────────────────────────────
# Sign cookies. Generate: `openssl rand -hex 32`. MUST be set in production.
SESSION_SECRET=dev-insecure-secret-change-me-in-production

# ── Proxy / rate limiting ────────────────────────────────────────────────────
# Trust X-Forwarded-For / X-Real-IP for the rate-limiter client IP. Enable ONLY
# when the app sits behind a reverse proxy (Caddy/Coolify) that OVERWRITES this
# header — otherwise clients can spoof it to evade rate limits.
TRUST_PROXY=false

# ── Email (Nodemailer SMTP) ──────────────────────────────────────────────────
# Leave SMTP_HOST empty to capture email in the dev outbox (data/outbox) instead
# of sending. For testing with Gmail, create an App Password (not your login
# password): Google Account → Security → 2-Step Verification → App passwords.
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-address@gmail.com
SMTP_PASS=your-16-char-app-password
MAIL_FROM=Norcineria Taccalite <your-address@gmail.com>

# Where reservation/order notifications for the shop are delivered
OWNER_EMAIL=owner@example.com

# ── Payments (Stripe, test mode) ─────────────────────────────────────────────
# Leave empty to run checkout in "simulate" mode (orders persist, no real charge)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Automation ───────────────────────────────────────────────────────────────
# Shared secret required by the /api/cron scheduled-jobs endpoint
CRON_SECRET=dev-cron-secret

# ── Bootstrap admin (seeded on first migration if no admin exists) ───────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=taccalite-admin
ADMIN_NAME=Amministratore
